---
import Logo from "@/components/Logo.astro";
import { settings } from "@/config/config.json";
import menu from "@/config/menu.json";
import { getSinglePage } from "@/lib/contentParser.astro";
import { IoSearch } from "react-icons/io5";

const postsZh = await getSinglePage("posts");
const postsEn = await getSinglePage("postsEn");
const enPostIds = new Set(postsEn.map((p) => p.id));
const zhListPages = Math.ceil(postsZh.length / settings.pagination);
const enListPages = Math.ceil(postsEn.length / settings.pagination);

function enHomeHrefForZhPage(pageNum: number) {
  if (enListPages <= 1) return "/en";
  const target = Math.min(pageNum, enListPages);
  return target <= 1 ? "/en" : `/en/page/${target}`;
}

function zhHomeHrefForEnPage(pageNum: number) {
  if (zhListPages <= 1) return "/";
  const target = Math.min(pageNum, zhListPages);
  return target <= 1 ? "/" : `/page/${target}`;
}

function normalizePath(pathname: string) {
  const p = pathname.replace(/\/$/, "");
  return p === "" ? "/" : p;
}

/** Bilingual routes: About + posts that exist in postsEn with same id */
type LangNav = { zhHref: string; enHref: string; current: "zh" | "en" };
let langNav: LangNav | null = null;
const path = normalizePath(Astro.url.pathname);

if (path === "/") {
  langNav = { zhHref: "/", enHref: "/en", current: "zh" };
} else if (path === "/en") {
  langNav = { zhHref: "/", enHref: "/en", current: "en" };
} else if (path === "/about") {
  langNav = { zhHref: "/about", enHref: "/en/about", current: "zh" };
} else if (path === "/en/about") {
  langNav = { zhHref: "/about", enHref: "/en/about", current: "en" };
} else if (path === "/portfolio") {
  langNav = {
    zhHref: "/portfolio",
    enHref: "/en/portfolio",
    current: "zh",
  };
} else if (path === "/en/portfolio") {
  langNav = {
    zhHref: "/portfolio",
    enHref: "/en/portfolio",
    current: "en",
  };
} else {
  const zhPaged = path.match(/^\/page\/(\d+)$/);
  if (zhPaged?.[1]) {
    const n = Number(zhPaged[1]);
    langNav = {
      zhHref: `/page/${n}`,
      enHref: enHomeHrefForZhPage(n),
      current: "zh",
    };
  }
  const enPaged = path.match(/^\/en\/page\/(\d+)$/);
  if (enPaged?.[1]) {
    const n = Number(enPaged[1]);
    langNav = {
      zhHref: zhHomeHrefForEnPage(n),
      enHref: `/en/page/${n}`,
      current: "en",
    };
  }
}

if (!langNav) {
  const zhPost = path.match(/^\/posts\/(.+)$/);
  if (zhPost?.[1] && enPostIds.has(zhPost[1])) {
    langNav = {
      zhHref: `/posts/${zhPost[1]}`,
      enHref: `/en/posts/${zhPost[1]}`,
      current: "zh",
    };
  }
  const enPost = path.match(/^\/en\/posts\/(.+)$/);
  if (enPost?.[1]) {
    langNav = {
      zhHref: `/posts/${enPost[1]}`,
      enHref: `/en/posts/${enPost[1]}`,
      current: "en",
    };
  }
}

export interface ChildNavigationLink {
  name: string;
  url: string;
}

export interface NavigationLink {
  name: string;
  url: string;
  hasChildren?: boolean;
  children?: ChildNavigationLink[];
}

const { main }: { main: NavigationLink[] } = menu;

const navLocale: "zh" | "en" = path.startsWith("/en") ? "en" : "zh";

function localizeMainLink(item: NavigationLink): NavigationLink {
  if (item.url === "/") {
    return {
      ...item,
      name: navLocale === "en" ? "Home" : "首頁",
      url: navLocale === "en" ? "/en" : "/",
    };
  }
  if (item.url === "/about") {
    return {
      ...item,
      name: navLocale === "en" ? "About" : "關於我",
      url: navLocale === "en" ? "/en/about" : "/about",
    };
  }
  if (item.url === "/portfolio") {
    return {
      ...item,
      name: navLocale === "en" ? "Portfolio" : "作品集",
      url: navLocale === "en" ? "/en/portfolio" : "/portfolio",
    };
  }
  return item;
}

const mainNav = main.map(localizeMainLink);

function isNavLinkActive(href: string): boolean {
  if (href === "/") return path === "/";
  if (href === "/en") return path === "/en";
  if (href === "/about") return path === "/about";
  if (href === "/en/about") return path === "/en/about";
  if (href === "/portfolio") return path === "/portfolio";
  if (href === "/en/portfolio") return path === "/en/portfolio";
  return path === href;
}

const logoHomeHref = navLocale === "en" ? "/en" : "/";
---

<header class="header sticky">
  <nav class="navbar container">
    <!-- logo -->
    <div class="order-0">
      <Logo homeHref={logoHomeHref} />
    </div>
    <!-- navbar toggler -->
    <input id="nav-toggle" type="checkbox" class="hidden" />
    <label
      id="show-button"
      for="nav-toggle"
      class="order-2 flex cursor-pointer items-center md:order-1 md:hidden"
    >
      <svg class="h-6 fill-current" viewBox="0 0 20 20">
        <title>Menu Open</title>
        <path d="M0 3h20v2H0V3z m0 6h20v2H0V9z m0 6h20v2H0V0z"></path>
      </svg>
    </label>
    <label
      id="hide-button"
      for="nav-toggle"
      class="order-2 hidden cursor-pointer items-center md:order-1"
    >
      <svg class="h-6 fill-current" viewBox="0 0 20 20">
        <title>Menu Close</title>
        <polygon
          points="11 9 22 9 22 11 11 11 11 22 9 22 9 11 -2 11 -2 9 9 9 9 -2 11 -2"
          transform="rotate(45 10 10)"></polygon>
      </svg>
    </label>
    <!-- /navbar toggler -->

    <ul
      id="nav-menu"
      class="navbar-nav order-3 hidden w-full items-center md:order-1 md:flex md:w-auto md:space-x-2"
    >
      {
        mainNav.map((menu) => (
          <>
            {menu.hasChildren ? (
              <li class="nav-item nav-dropdown group relative">
                <span class="nav-link inline-flex items-center">
                  {menu.name}
                  <svg class="h-4 w-4 fill-current" viewBox="0 0 20 20">
                    <path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z" />
                  </svg>
                </span>
                <ul class="nav-dropdown-list hidden group-hover:block md:invisible md:absolute md:block md:opacity-0 md:group-hover:visible md:group-hover:opacity-100">
                  {menu.children?.map((child) => (
                    <li class="nav-dropdown-item">
                      <a
                        href={child.url}
                        class={`nav-dropdown-link block ${
                          isNavLinkActive(child.url) && "active"
                        }`}
                      >
                        {child.name}
                      </a>
                    </li>
                  ))}
                </ul>
              </li>
            ) : (
              <li class="nav-item">
                <a
                  href={menu.url}
                  class={`nav-link block ${
                    isNavLinkActive(menu.url) && "active"
                  }`}
                >
                  {menu.name}
                </a>
              </li>
            )}
          </>
        ))
      }
      <li
        class="nav-item ms-auto flex flex-wrap items-center justify-center gap-3 max-md:mt-6 max-md:w-full md:gap-4"
      >
        {
          langNav && (
            <div
              class="inline-flex shrink-0 gap-0.5 rounded-md border border-border/50 bg-transparent p-0.5"
              role="tablist"
              aria-label="語言 Language"
            >
              <a
                href={langNav.zhHref}
                role="tab"
                aria-selected={langNav.current === "zh" ? "true" : "false"}
                class:list={[
                  "rounded px-3 py-1.5 text-sm font-medium transition-colors bg-transparent",
                  langNav.current === "zh"
                    ? "text-text-dark font-semibold hover:text-primary"
                    : "text-text/55 hover:text-primary",
                ]}
              >
                中文
              </a>
              <a
                href={langNav.enHref}
                role="tab"
                aria-selected={langNav.current === "en" ? "true" : "false"}
                class:list={[
                  "rounded px-3 py-1.5 text-sm font-medium transition-colors bg-transparent",
                  langNav.current === "en"
                    ? "text-text-dark font-semibold hover:text-primary"
                    : "text-text/55 hover:text-primary",
                ]}
              >
                EN
              </a>
            </div>
          )
        }
        <a
          class="inline-block cursor-pointer p-2 text-xl text-text-dark hover:text-primary md:block"
          href="/search"
        >
          <IoSearch />
        </a>
      </li>
    </ul>
  </nav>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    const header = document.querySelector(".header") as HTMLElement;
    window.addEventListener("scroll", () => {
      if (window.scrollY > 0) {
        header.classList.add("header-sticky");
      } else {
        header.classList.remove("header-sticky");
      }
    });
  });
</script>
