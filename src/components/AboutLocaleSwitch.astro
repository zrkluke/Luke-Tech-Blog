---
type Props = { current: "zh" | "en" };
const { current } = Astro.props;
---

<p class="mb-6 text-sm text-text-light">
  {
    current === "zh" ? (
      <>
        這份簡介另有{" "}
        <a href="/en/about" class="text-primary underline hover:opacity-80">
          English version
        </a>
        。
      </>
    ) : (
      <>
        This page is also available in{" "}
        <a href="/about" class="text-primary underline hover:opacity-80">
          中文
        </a>
        .
      </>
    )
  }
</p>
