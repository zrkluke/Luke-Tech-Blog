---
import AboutContact from "@/components/AboutContact.astro";
import Base from "@/layouts/Base.astro";
import { markdownify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import { getEntry, render } from "astro:content";

const page = await getEntry("pagesEn", "about");
if (!page) {
  throw new Error("Missing English About page (src/content/pages-en/about.md)");
}
const { title, meta_title, description, image } = page.data;
const { Content } = await render(page);
---

<Base
  title={title}
  meta_title={meta_title}
  description={description}
  image={image}
  htmlLang="en"
>
  <section class="section">
    <div class="container">
      <h1 set:html={markdownify(title)} class="h2 mb-8 text-primary" />
      <Image
        src="/images/author/luke-avatar.png"
        alt="Luke avatar"
        width={220}
        height={220}
        class="mx-auto mb-10 h-40 w-40 rounded-full object-cover shadow md:h-52 md:w-52"
      />
      <div class="content">
        <Content />
        <AboutContact locale="en" />
      </div>
    </div>
  </section>
</Base>
